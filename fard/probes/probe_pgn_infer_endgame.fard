import("std/fs") as fs
import("std/list") as list
import("std/str") as str

let pgn = fs.read_text("data/pgn/sample.pgn") in
let games = str.split(pgn, "\n\n\n") in
let g0 = list.get(games, 0) in
let moves = str.lower(g0) in
{
  contains_kq: str.contains(moves, "kq"),
  contains_rook: str.contains(moves, "rook"),
  contains_bishop: str.contains(moves, "bishop")
}
