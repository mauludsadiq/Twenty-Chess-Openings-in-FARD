import("std/fs") as fs
import("std/list") as list
import("std/str") as str

let pgn = fs.read_text("data/pgn/sample.pgn") in
let games = str.split(pgn, "\n\n") in
let bad = list.filter(games, fn(g) {
  str.contains(g, "[ECO ") == false
}) in
{
  game_chunks: list.len(games),
  bad_chunks: list.len(bad),
  first_bad: if list.len(bad) > 0 then list.get(bad, 0) else null
}
